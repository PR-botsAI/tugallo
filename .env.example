# --- Base de datos (Postgres / Neon) ---
# Usa la cadena de conexión DIRECTA de Neon (sin "-pooler"), termina en
# ?sslmode=require. Sirve para local y para producción (Vercel).
DATABASE_URL="postgresql://usuario:clave@ep-xxxx.us-east-2.aws.neon.tech/tugallo?sslmode=require"

# --- Sitio ---
# URL pública del sitio (para metadatos / Open Graph).
NEXT_PUBLIC_SITE_URL="https://tu-sitio.vercel.app"
