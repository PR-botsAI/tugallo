# --- Base de datos ---
# Desarrollo local (por defecto): SQLite, sin configuración.
DATABASE_URL="file:./dev.db"

# Producción: usa Postgres (Neon, Supabase, Vercel Postgres, etc.)
# y cambia `provider` a "postgresql" en prisma/schema.prisma.
# DATABASE_URL="postgresql://usuario:clave@host:5432/tugallo?sslmode=require"

# --- Sitio ---
# URL pública del sitio (para metadatos / Open Graph).
NEXT_PUBLIC_SITE_URL="https://tugallo.app"
